<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Modern Minimalist Clock Frame -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,22 A32,32 0 1,1 53.9,22"
        android:strokeWidth="3.5"
        android:strokeColor="#06B6D4" /> <!-- Neon Cyan rim -->
        
    <!-- Hour Ticks -->
    <!-- 12 o'clock -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,25 L54,30"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF" />
    <!-- 3 o'clock -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M83,54 L78,54"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF" />
    <!-- 6 o'clock -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,83 L54,78"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF" />
    <!--  o'clock -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M25,54 L30,54"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF" />

    <!-- Clock Hands with elegant angles -->
    <!-- Hour Hand (pointing roughly at 10) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,54 L40,42"
        android:strokeWidth="3.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
        
    <!-- Minute Hand (pointing to 2) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,54 L72,40"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Second Hand (Orange highlight for precision tracking, pointing to 6) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,54 L54,72"
        android:strokeWidth="1.5"
        android:strokeColor="#F97316"
        android:strokeLineCap="round" />

    <!-- Center Cap Pin -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,54 m-3,0 a3,3 0 1,1 6,0 a3,3 0 1,1 -6,0" />
    <path
        android:fillColor="#F97316"
        android:pathData="M54,54 m-1.5,0 a1.5,1.5 0 1,1 3,0 a1.5,1.5 0 1,1 -3,0" />
</vector>
